{
  "name": "itsmypassword-server",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable zero-knowledge sync server for ItsMyPassword",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:admin-ui": "node scripts/build-admin-ui.mjs",
    "build": "npm run build:admin-ui && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/store/migrate.ts"
  },
  "dependencies": {
    "@cloudflare/opaque-ts": "^0.7.5",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.2",
    "@fastify/static": "^9.1.3",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.1",
    "pino": "^9.5.0"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@preact/signals": "^2.9.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.17.0",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
