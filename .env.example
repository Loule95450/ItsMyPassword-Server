# --- Network ---
PORT=8080
HOST=0.0.0.0

# Optional separate port for the admin surface (admin web UI + approval
# endpoints). When set, admin routes are NOT served on PORT and the
# operator can bind the admin port to a private interface (loopback,
# Tailscale, …). When unset, admin and api share PORT.
#   ADMIN_PORT=8081
#   ADMIN_HOST=127.0.0.1
ADMIN_PORT=
ADMIN_HOST=127.0.0.1

# Trust X-Forwarded-* when behind Caddy/Traefik/nginx.
TRUST_PROXY=true

# Comma-separated origins allowed by CORS. Leave empty to disable CORS entirely.
# Example: CORS_ORIGINS=chrome-extension://abcdef..,https://my.keyfount.app
CORS_ORIGINS=

# --- Storage ---
DATABASE_PATH=/data/keyfount.db

# --- Logging ---
# One of: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- Secrets ---
# 32-byte HMAC key (base64). Used to hash emails and IPs at rest.
# Generate once and KEEP STABLE — rotating it invalidates all stored hashes.
#   openssl rand -base64 32
SERVER_HMAC_KEY=replace_me_base64_32_bytes
